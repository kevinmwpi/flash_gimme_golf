{
  "name": "flash-golf",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "server": "tsx server/index.ts",
    "dev:all": "concurrently -n web,ws -c blue,green \"npm run dev\" \"npm run server\"",
    "build": "tsc && vite build",
    "test": "vitest run",
    "preview": "vite preview --host 0.0.0.0"
  },
  "dependencies": {
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "ws": "8.19.0"
  },
  "devDependencies": {
    "@types/ws": "8.18.1",
    "concurrently": "9.2.1",
    "tsx": "4.21.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "4.7.0",
    "typescript": "5.9.3",
    "vite": "7.3.3",
    "vitest": "4.1.6"
  }
}
